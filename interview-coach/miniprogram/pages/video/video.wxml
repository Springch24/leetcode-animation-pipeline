<view class="container">
  <view class="video-header">
    <text class="video-num">LeetCode #{{id}}</text>
    <text class="video-title">{{name}}</text>
  </view>

  <!-- 视频播放区（小程序内用 video 组件，实际视频放云存储/CDN） -->
  <view class="video-area">
    <view class="video-placeholder">
      <text class="vp-icon">🎬</text>
      <text class="vp-text">动画讲解视频</text>
      <text class="vp-desc">竖屏1080×1920 · 约80秒</text>
    </view>
    <!-- 正式版替换为:
    <video
      src="{{videoUrl}}"
      controls
      autoplay
      object-fit="contain"
      style="width:100%;height:600rpx"
    /> -->
  </view>

  <!-- 题目信息 -->
  <view class="card">
    <view class="info-row">
      <text class="info-label">解题思路</text>
      <text class="info-value">{{approach}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">复杂度</text>
      <text class="info-value">{{complexity}}</text>
    </view>
    <view class="info-row" wx:if="{{goldLine}}">
      <text class="info-label">金句</text>
      <text class="info-value gold">💡 {{goldLine}}</text>
    </view>
  </view>

  <!-- 代码卡片 -->
  <view class="card" wx:if="{{codeCard}}">
    <image class="code-card-img" src="{{codeCard}}" mode="widthFix" />
  </view>

  <!-- 评论区引导 -->
  <view class="comment-guide">
    <text class="guide-text">{{commentPrompt}}</text>
  </view>
</view>
