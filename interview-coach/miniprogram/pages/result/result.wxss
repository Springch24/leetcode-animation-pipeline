.container { padding-bottom: 40rpx; }

.result-header {
  background: linear-gradient(180deg, #0d1326, #060b14);
  padding: 32rpx 24rpx;
}

.result-company {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #FCA311;
}

.result-count {
  display: block;
  font-size: 24rpx;
  color: #4a6080;
  margin-top: 8rpx;
}

.result-stats {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
}

.stat-item {
  font-size: 24rpx;
  color: #8a9ab5;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.filter-bar.sub {
  padding-top: 0;
}

.filter-item {
  flex-shrink: 0;
  padding: 10rpx 24rpx;
  background: #0d1326;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #4a6080;
  border: 2rpx solid transparent;
}

.filter-item.active {
  border-color: #FCA311;
  color: #FCA311;
}

/* 题目列表 */
.question-list {
  padding: 0 24rpx;
}

.question-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #0d1326;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
}

.q-left {
  display: flex;
  align-items: flex-start;
  flex: 1;
  min-width: 0;
}

.q-id {
  font-size: 26rpx;
  color: #FCA311;
  font-weight: 600;
  margin-right: 16rpx;
  min-width: 56rpx;
}

.q-info { flex: 1; min-width: 0; }

.q-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #dce4f0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.q-tags {
  display: flex;
  gap: 10rpx;
  margin-top: 8rpx;
}

.q-diff {
  font-size: 20rpx;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  background: #162040;
}

.q-tag {
  font-size: 20rpx;
  color: #4a6080;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  background: #162040;
}

.q-freq {
  font-size: 20rpx;
  color: #f87171;
}

.q-right { flex-shrink: 0; margin-left: 16rpx; }

/* 空状态 */
.empty { text-align: center; padding: 80rpx 0; }
.empty-text { font-size: 28rpx; color: #4a6080; }
