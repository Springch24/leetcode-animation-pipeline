<view class="container">
  <!-- 用户头像区 -->
  <view class="profile-card">
    <view class="avatar">
      <text class="avatar-text">👤</text>
    </view>
    <text class="nickname">算法练习生</text>
    <text class="subtitle">你的面试逆推之路</text>
  </view>

  <!-- 数据卡片 -->
  <view class="stats-row">
    <view class="stat-card">
      <text class="stat-num">{{historyCount}}</text>
      <text class="stat-label">查看记录</text>
    </view>
    <view class="stat-card">
      <text class="stat-num">{{savedCount}}</text>
      <text class="stat-label">收藏题目</text>
    </view>
    <view class="stat-card">
      <text class="stat-num">{{videoWatched}}</text>
      <text class="stat-label">已看视频</text>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goHistory">
      <text class="menu-icon">📋</text>
      <text class="menu-text">查看记录</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goSaved">
      <text class="menu-icon">⭐</text>
      <text class="menu-text">我的收藏</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于逆推器</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 订阅状态 -->
  <view class="card sub-card">
    <text class="sub-title">📊 题库更新日志</text>
    <text class="sub-desc">已收录 456 题 · 12 题有视频讲解</text>
    <text class="sub-desc">数据来源: LeetcodeTop 面经高频</text>
  </view>

  <!-- 底部 -->
  <view class="footer">
    <text class="footer-text">面试逆推器 v1.0 · Made with 🔥</text>
  </view>
</view>
