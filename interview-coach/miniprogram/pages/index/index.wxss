.container {
  padding: 24rpx;
  min-height: 100vh;
}

.hero {
  text-align: center;
  padding: 60rpx 0 40rpx;
}

.hero-title {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #FCA311;
  margin-bottom: 12rpx;
}

.hero-sub {
  display: block;
  font-size: 26rpx;
  color: #4a6080;
}

.section {
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

.step-badge {
  width: 40rpx;
  height: 40rpx;
  background: #FCA311;
  color: #060b14;
  border-radius: 50%;
  text-align: center;
  line-height: 40rpx;
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #dce4f0;
}

/* 公司网格 */
.company-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.company-item {
  width: calc(33.33% - 12rpx);
  background: #0d1326;
  border-radius: 16rpx;
  padding: 24rpx 12rpx;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.company-item.active {
  border-color: #FCA311;
  background: #162040;
}

.company-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #dce4f0;
  margin-bottom: 8rpx;
}

.company-count {
  font-size: 22rpx;
  color: #4a6080;
}

/* 岗位列表 */
.role-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.role-item {
  background: #0d1326;
  border-radius: 12rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  color: #8a9ab5;
  border: 2rpx solid transparent;
}

.role-item.active {
  border-color: #FCA311;
  color: #FCA311;
  background: #162040;
}

/* 搜索按钮 */
.search-box {
  background: linear-gradient(135deg, #FCA311, #e8910a);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.search-icon {
  font-size: 36rpx;
}

.search-text {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #060b14;
  margin-left: 16rpx;
}

.search-arrow {
  font-size: 32rpx;
  color: #060b14;
  font-weight: 700;
}

/* 底部统计 */
.stats {
  text-align: center;
  padding: 40rpx 0;
}

.stats-text {
  font-size: 24rpx;
  color: #4a6080;
}
